<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="WindowApp.MainWindow"
        Title="Problem Plecakowy"
        Width="400" Height="700">
        
    <StackPanel Margin="20" Spacing="10">
    <TextBlock Text="Liczba przedmiotów (N):" />
    <TextBox Name="TxtN" Text="10" />
    
    <TextBlock Text="Seed:" />
    <TextBox Name="TxtSeed" Text="2" />
    
    <TextBlock Text="Pojemność:" />
    <TextBox Name="TxtCapacity" Text="10" />
    
    <Button Content="Uruchom algorytm" Click="BtnSolve_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
    <TextBox Name="Txtwylosowane" Text="Tu będą wylosowane przedmioty:" Height="250" />
    <TextBlock Text="Wyniki:" />
    <TextBox Name="TxtResult" Height="100" AcceptsReturn="True" IsReadOnly="True" />
</StackPanel>
</Window>
